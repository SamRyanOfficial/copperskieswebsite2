{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "copperskies.co.nz"
        }
      ],
      "destination": "https://www.copperskies.co.nz/:path*",
      "permanent": true
    }
  ]
}
